# ---------- MODULE 2 : SAISIE ----------
@app.route('/saisie')
def saisie():
    etudiants = Etudiant.query.all()
    matieres = Matiere.query.all()
    filieres = Filiere.query.all()
    absences_non_justifiees = Absence.query.filter_by(justifiee=False, status='absent').all()
    return render_template('saisie.html', etudiants=etudiants, matieres=matieres,
                           filieres=filieres, absences_non_justifiees=absences_non_justifiees)

@app.route('/inscrire_etudiant', methods=['POST'])
def inscrire_etudiant():
    nom = request.form['nom']
    prenom = request.form['prenom']
    matricule = request.form['matricule']
    filiere_id = request.form['filiere_id']
    etudiant = Etudiant(nom=nom, prenom=prenom, matricule=matricule, filiere_id=filiere_id)
    db.session.add(etudiant)
    db.session.commit()
    flash('Étudiant inscrit', 'success')
    return redirect(url_for('saisie'))

@app.route('/enregistrer_presence', methods=['POST'])
def enregistrer_presence():
    etudiant_id = request.form['etudiant_id']
    matiere_id = request.form['matiere_id']
    date_abs = datetime.strptime(request.form['date'], '%Y-%m-%d').date()
    status = request.form['status']
    envoyer_message = 'envoyer_message' in request.form

    absence = Absence(etudiant_id=etudiant_id, matiere_id=matiere_id,
                      date=date_abs, status=status, message_envoye=False)
    if status == 'absent' and envoyer_message:
        absence.message_envoye = True
        flash(f'📨 Message envoyé à l\'étudiant concernant l\'absence du {date_abs}', 'info')
    db.session.add(absence)
    db.session.commit()
    flash('Présence/absence enregistrée', 'success')
    return redirect(url_for('saisie'))

@app.route('/justifier_absence/<int:id>', methods=['POST'])
def justifier_absence(id):
    absence = Absence.query.get_or_404(id)
    justification = request.form['justification']
    absence.justification = justification
    absence.justifiee = True
    db.session.commit()
    flash('Absence justifiée', 'success')
    return redirect(url_for('saisie'))


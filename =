@app.route('/edition')
def edition():
    filieres = Filiere.query.all()
    periodes = Periode.query.all()
    etudiants = Etudiant.query.all()
    absences_justifiees = Absence.query.filter_by(justifiee=True).all()
    return render_template('edition.html', filieres=filieres, periodes=periodes,
                           etudiants=etudiants, absences_justifiees=absences_justifiees)

@app.route('/absence_par_periode/<int:periode_id>')
def absence_par_periode(periode_id):
    periode = Periode.query.get_or_404(periode_id)
    absences = Absence.query.join(Etudiant).filter(
        Absence.date.between(periode.date_debut, periode.date_fin),
        Absence.status == 'absent'
    ).all()
    result = {}
    for absence in absences:
        filiere_nom = absence.etudiant.filiere.nom
        result[filiere_nom] = result.get(filiere_nom, 0) + 1
    return render_template('rapport_periode.html', periode=periode, result=result)

@app.route('/rapport_etudiant/<int:etudiant_id>')
def rapport_etudiant(etudiant_id):
    etudiant = Etudiant.query.get_or_404(etudiant_id)
    absences = Absence.query.filter_by(etudiant_id=etudiant_id).all()
    presents = [a for a in absences if a.status == 'present']
    absents = [a for a in absences if a.status == 'absent']
    justifiees = [a for a in absents if a.justifiee]
    return render_template('rapport_etudiant.html', etudiant=etudiant,
                           presents=presents, absents=absents, justifiees=justifiees)

if __name__ == '__main__':
